{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js?path=:path*"
    },
    {
      "source": "/logs",
      "destination": "/index.html"
    },
    {
      "source": "/logs/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/signup",
      "destination": "/index.html"
    }
  ]
}
